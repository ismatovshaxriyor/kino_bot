# ===================== KinoBot .env namunasi =====================
# Bu faylni `.env` ga nusxalang va qiymatlarni to'ldiring:
#     cp .env.example .env
# `.env` hech qachon git'ga qo'shilmaydi (.gitignore).

# ---------- Telegram (MAJBURIY) ----------
BOT_TOKEN=
ADMIN_ID=
MANAGER_ID=

# ---------- Ma'lumotlar bazasi (MAJBURIY) ----------
# DIQQAT (Docker): bot/worker konteynerlari ichida DB_HOST=db va DB_PORT=5432
# qiymatlarini docker-compose.yml AVTOMATIK o'rnatadi. Bu yerdagi DB_HOST/DB_PORT
# faqat host'dan ishlaganda (lokal dev, host'dagi psql) ishlatiladi.
# Productionda KUCHLI DB_PASSWORD qo'ying.
DB_NAME=kinobot
DB_USER=kinobot
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ---------- Redis (ixtiyoriy) ----------
# Docker'da compose buni redis://redis ga o'rnatadi. Lokal dev'da default mos keladi.
# REDIS_URL=redis://localhost

# ---------- Gemini AI (ixtiyoriy — bo'lmasa AI funksiyalari ishlamaydi) ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GENAI_TEMPERATURE=0.5
GENAI_MAX_OUTPUT_TOKENS=900

# ---------- Backup (ixtiyoriy) ----------
# To'liq Docker'da pg_dump bot image ichida mavjud (postgresql-client-15) va
# tarmoq orqali ishlaydi — bularni bo'sh qoldiring.
# Faqat host'da pg_dump bo'lmagan boshqa stsenariylarda kerak bo'ladi:
# PG_DUMP_PATH=/usr/bin/pg_dump
# DB_DOCKER_CONTAINER=my_bot_postgres

# ---------- Inline thumbnail (ixtiyoriy) ----------
# INLINE_THUMB_URL=
